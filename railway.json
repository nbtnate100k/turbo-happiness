{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK"
  },
  "deploy": {
    "startCommand": "gunicorn pluxo_backend:app --bind 0.0.0.0:$PORT --workers 1 --threads 4 --timeout 120 --access-logfile -",
    "healthcheckPath": "/pluxo-ok",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE"
  }
}
